                <mxCell id="c17" value="8. signtool sign /fd SHA256" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFD54F;fontColor=#E65100;fontSize=12;fontStyle=1;shadow=1;textShadow=1;align=center;verticalAlign=middle;sketch=0;" vertex="1" parent="c5"><mxGeometry x="20" y="760" width="220" height="60" as="geometry"/></mxCell>
                <mxCell id="c18" value="9. signtool verify /pa" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#CE93D8;fontColor=#4A148C;fontSize=12;fontStyle=1;shadow=1;textShadow=1;align=center;verticalAlign=middle;sketch=0;" vertex="1" parent="c5"><mxGeometry x="20" y="860" width="220" height="60" as="geometry"/></mxCell>
                <mxCell id="c19" value="10. Generate SHA256 checksum" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#CE93D8;fontColor=#4A148C;fontSize=12;fontStyle=1;shadow=1;textShadow=1;align=center;verticalAlign=middle;sketch=0;" vertex="1" parent="c5"><mxGeometry x="20" y="960" width="220" height="60" as="geometry"/></mxCell>
