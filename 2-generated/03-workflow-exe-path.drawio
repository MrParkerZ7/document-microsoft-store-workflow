                <mxCell id="c14" value="5. release.yml triggers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#CE93D8;fontColor=#4A148C;fontSize=12;fontStyle=1;shadow=1;textShadow=1;align=center;verticalAlign=middle;sketch=0;" vertex="1" parent="c5"><mxGeometry x="20" y="460" width="220" height="60" as="geometry"/></mxCell>
