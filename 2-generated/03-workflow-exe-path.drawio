                <mxCell id="c7" value="Partner Center" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontColor=#0D47A1;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;shadow=1;textShadow=1;dashed=0;sketch=0;" vertex="1" parent="1"><mxGeometry x="880" y="100" width="260" height="1560" as="geometry"/></mxCell>
                <mxCell id="c8" value="End User" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFB74D;fontColor=#E65100;fontSize=13;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;shadow=1;textShadow=1;dashed=0;sketch=0;" vertex="1" parent="1"><mxGeometry x="1160" y="100" width="260" height="1560" as="geometry"/></mxCell>
                <mxCell id="c9" value="1. Buy code signing cert&#10;(~$120-700/yr)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFD54F;fontColor=#E65100;fontSize=12;fontStyle=1;shadow=1;textShadow=1;align=center;verticalAlign=middle;sketch=0;" vertex="1" parent="c4"><mxGeometry x="20" y="60" width="220" height="60" as="geometry"/></mxCell>
                <mxCell id="c10" value="2. Add CERTIFICATE_PFX&#10;+ PASSWORD secrets" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFD54F;fontColor=#E65100;fontSize=12;fontStyle=1;shadow=1;textShadow=1;align=center;verticalAlign=middle;sketch=0;" vertex="1" parent="c4"><mxGeometry x="20" y="160" width="220" height="60" as="geometry"/></mxCell>
                <mxCell id="c11" value="3. Reserve app&#10;as 'EXE or MSI'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#9FA8DA;fontColor=#1A237E;fontSize=12;fontStyle=1;shadow=1;textShadow=1;align=center;verticalAlign=middle;sketch=0;" vertex="1" parent="c4"><mxGeometry x="20" y="260" width="220" height="60" as="geometry"/></mxCell>
                <mxCell id="c12" value="4. git tag v1.0.0&#10;+ git push tag" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#9FA8DA;fontColor=#1A237E;fontSize=12;fontStyle=1;shadow=1;textShadow=1;align=center;verticalAlign=middle;sketch=0;" vertex="1" parent="c4"><mxGeometry x="20" y="360" width="220" height="60" as="geometry"/></mxCell>
