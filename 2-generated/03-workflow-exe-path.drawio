                <mxCell id="c3" value="Developer hosts signed .exe publicly; Microsoft downloads via URL. Code signing cert REQUIRED." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=0;fontColor=#263238;textShadow=1;" vertex="1" parent="1"><mxGeometry x="40" y="50" width="1320" height="20" as="geometry"/></mxCell>
